# Optional. Server-side API keys used by /api/generate when a user hasn't
# provided their own key in Settings (BYOK). Set the one(s) matching the
# provider(s) you want available. Without any key (server or BYOK), everything
# works except AI card generation.
#
# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional. Supabase enables optional cloud accounts (email + password) and
# last-write-wins data sync. Without these, the app stays fully offline and the
# account/sync UI hides itself. Find both in your Supabase project:
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
# New-style publishable key (sb_publishable_…), safe to expose to the browser.
# Replaces the legacy anon key; either works with @supabase/ssr.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secret key (sb_secret_…). Bypasses RLS — keep it private, never
# prefix with NEXT_PUBLIC. Used by the Lemon Squeezy webhook to credit accounts.
SUPABASE_SECRET_KEY=

# ── AI credits via Lemon Squeezy ─────────────────────────────────────────────
# Optional. Lets signed-in users buy credits to use server-side AI. Without
# these, the buy-credits flow is hidden (BYOK + the free starter grant still
# work). From your Lemon Squeezy dashboard:
#   API key:   Settings → API
#   Store ID:  Settings → Stores (the numeric id)
#   Variants:  create a "Lexio credits" product with one variant per pack,
#              then copy each variant's id. Credit amounts per pack live in
#              src/lib/credits/packs.ts — set your Lemon Squeezy prices to match.
#   Webhook secret: Settings → Webhooks → add the signing secret you set when
#              creating the webhook pointing at /api/webhooks/lemonsqueezy.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_SMALL=
LEMONSQUEEZY_VARIANT_MEDIUM=
LEMONSQUEEZY_VARIANT_LARGE=
