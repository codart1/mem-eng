# Optional. Server-side API keys used by /api/generate when a user hasn't
# provided their own key in Settings (BYOK). Set the one(s) matching the
# provider(s) you want available. Without any key (server or BYOK), everything
# works except AI card generation.
#
# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional. Supabase enables optional cloud accounts (email + password) and
# last-write-wins data sync. Without these, the app stays fully offline and the
# account/sync UI hides itself. Find both in your Supabase project:
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
# New-style publishable key (sb_publishable_…), safe to expose to the browser.
# Replaces the legacy anon key; either works with @supabase/ssr.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
